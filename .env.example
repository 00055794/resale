# Public config keys only. Do not commit real secrets.

# Halyk SSO (OIDC)
HALYK_SSO_ISSUER=https://sso.halykbank.kz/realms/homebank
HALYK_SSO_CLIENT_ID=resale-web
HALYK_SSO_REDIRECT_URI=https://homebank.kz/services/resale/callback

# Google Maps
GOOGLE_MAPS_API_KEY=

# Krisha.kz price source
KRISHA_BASE_URL=https://krisha.kz
KRISHA_SCRAPE_MODE=adapter   # adapter | live | mock

# CBS (Core Banking System) mortgage application push
CBS_BASE_URL=https://cbs.halykbank.kz/api/v1
CBS_API_KEY=
CBS_MODE=mock                # mock | live

# GenAI provider (OpenAI-compatible)
GENAI_BASE_URL=https://api.openai.com/v1
GENAI_API_KEY=
GENAI_MODEL=gpt-4o-mini
GENAI_MODE=mock              # mock | live

# Database / cache
DATABASE_URL=postgresql+psycopg://resale:resale@db:5432/resale
REDIS_URL=redis://cache:6379/0

# Observability
LOG_LEVEL=INFO
METRICS_ENABLED=true
TRACING_ENDPOINT=

# Security: comma-separated allowed CORS origins ("*" = dev only)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://127.0.0.1:5173

# Web frontend (Vite). Only VITE_-prefixed keys are exposed to the browser bundle.
VITE_API_URL=http://localhost:8000
VITE_GOOGLE_MAPS_API_KEY=
